<?xml version="1.0"?>
<ruleset name="shikiphp">
    <description>shikiphp coding standard</description>

    <file>src</file>
    <file>tests</file>

    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12"/>

    <exclude-pattern>src/Regex/*</exclude-pattern>

    <rule ref="PSR1.Methods.CamelCapsMethodName.NotCamelCaps">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
</ruleset>
